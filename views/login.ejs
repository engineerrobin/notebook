<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/login.css">
</head>
<body>
    <main class="auth-page">
        <section class="auth-card" aria-label="登录表单">
            <p class="brand">Notebook</p>
            <h1>登录记账本</h1>
            <p class="desc">简洁登录，快速回到账单管理。</p>

            <form id="loginForm" class="auth-form" novalidate>
                <label class="field">
                    <span>用户名</span>
                    <input id="usernameInput" name="username" type="text" maxlength="20" placeholder="请输入用户名" required>
                </label>

                <label class="field">
                    <span>密码</span>
                    <input id="passwordInput" name="password" type="password" minlength="6" placeholder="请输入密码" required>
                </label>

                <div class="row">
                    <label class="check">
                        <input id="rememberInput" type="checkbox">
                        <span>记住我</span>
                    </label>
                    <a class="text-link" href="/acount/register">去注册</a>
                </div>

                <p id="formMessage" class="form-message" hidden></p>

                <button class="btn btn--primary" type="submit">登 录</button>
            </form>

            <p class="footer-link">还没有账号？<a href="/acount/register">立即注册</a></p>
        </section>
    </main>

    <script src="/javascripts/login.js"></script>
</body>
</html>
